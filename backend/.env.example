# ================================
# SERVER
# ================================
NODE_ENV=development
PORT=4000

# ================================
# DATABASE (MySQL)
# ================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=coma_db
DB_USER=root
DB_PASSWORD=your_db_password

# ================================
# JWT Authentication
# ================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# ================================
# AWS
# ================================
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=coma-bucket

# ================================
# KAKAO OAuth
# ================================
KAKAO_REST_API_KEY=your_kakao_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret_key
KAKAO_REDIRECT_URI=http://localhost:5173/auth/callback

# ================================
# KAKAO JS SDK
# ================================
VITE_API_URL=http://localhost:4000/api  
VITE_SOCKET_URL=http://localhost:4000
VITE_KAKAO_JS_KEY=발급받은_JavaScript_키     # ← 카카오 공유 기능용
VITE_APP_URL=http://localhost:5173           # ← 프론트엔드 URL (공유 기능에서 사용)


# ================================
# NAVER OAuth
# ================================
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost:5173/auth/naver/callback

# ================================
# CORS
# ================================
CLIENT_URL=http://localhost:5173

# ================================
# Socket.IO
# ================================
SOCKET_CORS_ORIGIN=http://localhost:5173
